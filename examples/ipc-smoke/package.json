{
  "name": "bunite-ipc-smoke-example",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:renderer": "bun scripts/prepare-renderer.ts",
    "dev": "bun run prepare:renderer && bun src/main.ts",
    "smoke": "bun run prepare:renderer && bun src/smoke.ts",
    "build": "bun run prepare:renderer && bun build src/main.ts --target bun --outfile dist/main.js",
    "start": "bun dist/main.js"
  },
  "dependencies": {
    "bunite-core": "workspace:*"
  }
}
