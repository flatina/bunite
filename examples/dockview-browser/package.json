{
  "name": "dockview-browser",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx vite build && bun src/main.ts",
    "build": "bunite-build && bunx vite build",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit && bun x tsc -p src/renderer/tsconfig.json --noEmit"
  },
  "dependencies": {
    "bunite-core": "workspace:*",
    "bunite-native-win-x64": "workspace:*",
    "dockview-core": "^5.1.0"
  },
  "devDependencies": {
    "bunite-dev": "workspace:*",
    "vite": "^6"
  }
}
